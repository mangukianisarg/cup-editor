FROM node:22-alpine AS build
WORKDIR /app
RUN corepack enable
COPY package.json pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/package.json
RUN pnpm install --filter @ecocarry/web --frozen-lockfile=false
COPY apps/web apps/web
RUN pnpm --filter @ecocarry/web build

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY --from=build /app/apps/web/dist apps/web/dist
COPY --from=build /app/apps/web/server.js apps/web/server.js
COPY --from=build /app/apps/web/openai-artwork-api.js apps/web/openai-artwork-api.js
COPY --from=build /app/apps/web/package.json apps/web/package.json
EXPOSE 5173
CMD ["node", "apps/web/server.js"]
